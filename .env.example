# You can override these if using an external MySQL
WORDPRESS_DB_HOST=db
WORDPRESS_DB_USER=wp
WORDPRESS_DB_PASSWORD=wp
WORDPRESS_DB_NAME=wordpress_test

# Ko-fi verification token
KOFI_VERIFICATION_TOKEN=

# Development site URL for integration tests
WP_TEST_SITE_URL=

# WordPress core ref used by automated PHPUnit tests (branch or tag in wordpress-develop).
# Set this to match dev.foodgeek.dk, e.g. 6.9.1
WP_DEVELOP_REF=6.9.1

# WordPress.org SVN credentials (used by: make commit-svn)
WPORG_USER=
WPORG_PASS=
